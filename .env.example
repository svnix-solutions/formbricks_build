# ─────────────────────────────────────────────────────────────────────────────
# Formbricks self-host — environment configuration
#
# PRIMARY use with Komodo: paste these (filled in) into the Stack's "Environment"
# field. Komodo writes them to `.env` in the run directory and runs
# `docker compose up -d --env-file .env`. Do NOT commit a real `.env` — only this
# template is tracked. (You may also copy to `.env` for local `docker compose` testing.)
#
# Generate each secret with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

########################## REQUIRED — URLs ##########################
# Public Cloudflare Tunnel hostname for this instance.
WEBAPP_URL=https://forms.example.com
# Must be identical to WEBAPP_URL.
NEXTAUTH_URL=https://forms.example.com

########################## REQUIRED — Secrets #######################
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
ENCRYPTION_KEY=replace-with-openssl-rand-hex-32
CRON_SECRET=replace-with-openssl-rand-hex-32
HUB_API_KEY=replace-with-openssl-rand-hex-32
CUBEJS_API_SECRET=replace-with-openssl-rand-hex-32

########################## Database #################################
# Password for the bundled postgres. Change from the default before first boot.
# DATABASE_URL / Cube / Hub all derive from this automatically.
POSTGRES_PASSWORD=change-me-strong-password

########################## Networking ##############################
# External docker network shared with the separate cloudflared stack.
# Must be created before first deploy:  docker network create cloudflared
PROXY_NETWORK=cloudflared
# Name of this stack's private network (postgres/redis/hub/cube). Owned by this stack.
# INTERNAL_NETWORK=formbricks_internal

########################## Image pinning (optional) #################
# Leave unset to track :latest. To pin a release, set the tag WITH the leading colon:
# FB_IMAGE_REF=:5.1.4
# HUB_IMAGE_REF=:latest

########################## Email / SMTP (optional) #################
# Required for password reset & email verification. If you configure SMTP, also
# set the two toggles below to 0 to turn those flows on.
# MAIL_FROM=forms@example.com
# MAIL_FROM_NAME=Formbricks
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_AUTHENTICATED=1
# SMTP_SECURE_ENABLED=0            # set 1 for TLS on port 465
# EMAIL_VERIFICATION_DISABLED=0
# PASSWORD_RESET_DISABLED=0

########################## Enterprise (optional) ###################
# ENTERPRISE_LICENSE_KEY=

########################## OAuth / SSO (optional) ##################
# GITHUB_ID=
# GITHUB_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# AZUREAD_CLIENT_ID=
# AZUREAD_CLIENT_SECRET=
# AZUREAD_TENANT_ID=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_ISSUER=
# OIDC_DISPLAY_NAME=
# AUTH_SKIP_INVITE_FOR_SSO=1

########################## S3 storage (optional) ##################
# Needed for file uploads if you move off the local disk / scale out.
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=
# S3_BUCKET_NAME=
# S3_ENDPOINT_URL=
# S3_FORCE_PATH_STYLE=0

########################## Misc (optional) ########################
# LOG_LEVEL=info
# RATE_LIMITING_DISABLED=0
# TELEMETRY_DISABLED=1
# UNSPLASH_ACCESS_KEY=
